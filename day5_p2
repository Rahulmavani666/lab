import java.util.Scanner;

public class Factorial {

    // Cache array (0! to 20!)
    static long[] fact = new long[21];

    // Method to compute factorial
    public static long getFactorial(int x) {

        // Validation using IllegalArgumentException
        if (x < 0) {
            throw new IllegalArgumentException("value of x must be positive");
        }

        if (x >= fact.length) {
            throw new IllegalArgumentException("result will overflow.");
        }

        // Reuse if already computed
        if (fact[x] != 0) {
            return fact[x];
        }

        long result = 1;

        for (int i = 1; i <= x; i++) {
            result *= i;
        }

        fact[x] = result; // store in array
        return result;
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        try {
            System.out.print("Enter value of x: ");
            int x = sc.nextInt();

            long ans = getFactorial(x);
            System.out.println("Factorial of " + x + " = " + ans);

        } catch (IllegalArgumentException e) {
            System.out.println("Error: " + e.getMessage());
        } catch (Exception e) {
            System.out.println("Invalid input");
        }

        sc.close();
    }
}
