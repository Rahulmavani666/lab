public class MultiThreadedTables {

    private static class TableThread extends Thread {
        private final int number;

        TableThread(int number) {
            this.number = number;
        }

        @Override
        public void run() {
            System.out.println("Table of " + number + " started by " + Thread.currentThread().getName());

            for (int i = 1; i <= 10; i++) {
                System.out.println(number + " x " + i + " = " + (number * i));
                try {
                    Thread.sleep(200); // small delay so interleaving is visible
                } catch (InterruptedException e) {
                    return;
                }
            }

            System.out.println("Table of " + number + " finished by " + Thread.currentThread().getName());
        }
    }

    public static void main(String[] args) throws InterruptedException {
        Thread t2 = new TableThread(2);
        Thread t3 = new TableThread(3);
        Thread t4 = new TableThread(4);

        t2.start();
        t3.start();
        t4.start();

        // Wait until all tables are done
        t2.join();
        t3.join();
        t4.join();

        System.out.println("All tables completed.");
    }
}
