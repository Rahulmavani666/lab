import java.util.Scanner;
import java.time.LocalDate;

class Baby {

    String name;
    LocalDate dob;
    LocalDate polioDate;

    Baby(String name, LocalDate dob) {
        this.name = name;
        this.dob = dob;
        this.polioDate = dob.plusDays(45);   // calculate polio date
    }

    void display() {
        System.out.println("Baby Name: " + name);
        System.out.println("Date of Birth: " + dob);
        System.out.println("Polio Drop Date: " + polioDate);
    }
}

public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter Baby Name: ");
        String name = sc.nextLine();

        System.out.print("Enter Date of Birth (YYYY-MM-DD): ");
        String date = sc.nextLine();

        LocalDate dob = LocalDate.parse(date);

        Baby b = new Baby(name, dob);
        b.display();
    }
}
