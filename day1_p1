import java.util.*;

class factorial{
    public static int fact(int n){
        if(n==0||n==1) return 1;
        return n*fact(n-1);
    }
}
public class main{
     public static void main(String[] arg){
         Scanner sc= new Scanner(System.in);
         int n=sc.nextInt();
         
         factorial f1= new factorial();
         
         System.out.println(f1.fact(n));
     }
}
