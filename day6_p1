import java.util.Random;

public class PingPongRandom {

    private static class Printer extends Thread {
        private final String text;
        private final Random random = new Random();

        Printer(String text) {
            this.text = text;
        }

        @Override
        public void run() {
            while (true) {
                System.out.println(text);

                try {
                    // Base interval = 1 second, plus a random extra delay (0 to 1000 ms)
                    Thread.sleep(1000 + random.nextInt(1001));
                } catch (InterruptedException e) {
                    // Stop thread gracefully if interrupted
                    return;
                }
            }
        }
    }

    public static void main(String[] args) {
        new Printer("Ping").start();
        new Printer("PONG").start();
    }
}
