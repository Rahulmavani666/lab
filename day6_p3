import java.util.LinkedList;
import java.util.Queue;

public class ProducerConsumer {

    private static class BoundedBuffer {
        private final Queue<Integer> queue = new LinkedList<>();
        private final int capacity;

        BoundedBuffer(int capacity) {
            this.capacity = capacity;
        }

        public synchronized void produce(int value) throws InterruptedException {
            while (queue.size() == capacity) {
                wait(); // buffer full, producer waits
            }
            queue.add(value);
            System.out.println("Produced: " + value + " | Buffer size: " + queue.size());
            notifyAll(); // wake consumers
        }

        public synchronized int consume() throws InterruptedException {
            while (queue.isEmpty()) {
                wait(); // buffer empty, consumer waits
            }
            int value = queue.remove();
            System.out.println("Consumed: " + value + " | Buffer size: " + queue.size());
            notifyAll(); // wake producers
            return value;
        }
    }

    private static class Producer extends Thread {
        private final BoundedBuffer buffer;

        Producer(BoundedBuffer buffer) {
            this.buffer = buffer;
        }

        @Override
        public void run() {
            int value = 1;
            while (true) {
                try {
                    buffer.produce(value++);
                    Thread.sleep(300);
                } catch (InterruptedException e) {
                    return;
                }
            }
        }
    }

    private static class Consumer extends Thread {
        private final BoundedBuffer buffer;

        Consumer(BoundedBuffer buffer) {
            this.buffer = buffer;
        }

        @Override
        public void run() {
            while (true) {
                try {
                    buffer.consume();
                    Thread.sleep(500);
                } catch (InterruptedException e) {
                    return;
                }
            }
        }
    }

    public static void main(String[] args) {
        BoundedBuffer buffer = new BoundedBuffer(5);

        new Producer(buffer).start();
        new Consumer(buffer).start();
    }
}
